      <tr class="text-start">
        <td class="border border-dark align-middle text-center">
          <b>Conclusiones del Análisis Cromatográfico</b> 
        </td>
        <td class="border border-dark">

<%# @chromatographical.iec_color_hidrogeno_report   == "success" &&
            @chromatographical.iec_color_metano_report      == "success" &&
            @chromatographical.iec_color_monocarbono_report == "success" &&
            @chromatographical.iec_color_diocarbono_report  == "success" &&
            @chromatographical.iec_color_etileno_report     == "success" &&
            @chromatographical.iec_color_etano_report       == "success" &&
            @chromatographical.iec_color_acetileno_report   == "success" %>

			<% if @transformer.con_cro.blank? or @transformer.con_cro.nil? or @transformer.con_cro == ""  %>          
				<!-- TODO OK -->
				<% if @chromatographical.iec_color_hidrogeno_report         == "success" &&
				            @chromatographical.iec_color_metano_report      == "success" &&
				            @chromatographical.iec_color_monocarbono_report == "success" &&
				            @chromatographical.iec_color_diocarbono_report  == "success" &&
				            @chromatographical.iec_color_etileno_report     == "success" &&
				            @chromatographical.iec_color_etano_report       == "success" &&
				            @chromatographical.iec_color_acetileno_report   == "success" %>
				Las concentraciones de los gases combustibles se encuentran por debajo del umbral típico sin indicios de defectos térmicos o eléctrico. 
				<% else %>
				Los gases combustibles observados se asocian a:
					<!-- hid y met  -->
					<% if @chromatographical.iec_color_hidrogeno_report   == "danger" or
					      @chromatographical.iec_color_metano_report      == "danger" or
					      @chromatographical.iec_color_hidrogeno_report   == "warning" or
					      @chromatographical.iec_color_metano_report      == "warning"  %>
					<li>  Descargas parciales. </li>
					<% end %>

					<!-- mon y dio  -->
					<% if @chromatographical.iec_color_monocarbono_report   == "danger" or
					      @chromatographical.iec_color_diocarbono_report    == "danger" or
					      @chromatographical.iec_color_monocarbono_report   == "warning" or
					      @chromatographical.iec_color_diocarbono_report    == "warning"  %>
					<li>  Degradación del aislamiento sólido. </li>
					<% end %>

					<!-- eti y eta  -->
					<% if @chromatographical.iec_color_etileno_report   == "danger" or
					      @chromatographical.iec_color_etano_report     == "danger" or
					      @chromatographical.iec_color_etileno_report   == "warning" or
					      @chromatographical.iec_color_etano_report     == "warning" %>
					<li>  Defectos térmicos</li> 
					<% end %>

					<!-- ace  -->
					<% if @chromatographical.iec_color_acetileno_report   == "danger" or
					      @chromatographical.iec_color_acetileno_report   == "warning" %>
					<li>  Descargas eléctricas </li>
					<% end %>


				<% end %>
			<% else %>
			  <%= simple_format(@transformer.con_cro) %>
			<% end %>

			<% if @chromatographical.iec_color_hidrogeno_report             == "danger" or
				            @chromatographical.iec_color_metano_report      == "danger" or
				            @chromatographical.iec_color_monocarbono_report == "danger" or
				            @chromatographical.iec_color_diocarbono_report  == "danger" or
				            @chromatographical.iec_color_etileno_report     == "danger" or
				            @chromatographical.iec_color_etano_report       == "danger" or
				            @chromatographical.iec_color_acetileno_report   == "danger" %>

				<br>
				El resultado por Triángulo Duval indica:
				<li> <%= @tri1 %></li>
				<br>
				El resultado por Pentágono Duval indica:
				<li> <%= @pen1 %></li>
			<% end %>



        </td>        
      </tr>
      <tr class="text-start">
        <td class="border border-dark align-middle text-center">
          <b>Recomendaciones de Análisis Cromatográfico</b> 
         </td>
        <td class="border border-dark">
			<% if @transformer.rec_cro.blank? or @transformer.rec_cro.nil? or @transformer.rec_cro == ""  %>          	
				<!-- TODO OK -->
				<% if @chromatographical.iec_color_hidrogeno_report   == "success" &&
				            @chromatographical.iec_color_metano_report      == "success" &&
				            @chromatographical.iec_color_monocarbono_report == "success" &&
				            @chromatographical.iec_color_diocarbono_report  == "success" &&
				            @chromatographical.iec_color_etileno_report     == "success" &&
				            @chromatographical.iec_color_etano_report       == "success" &&
				            @chromatographical.iec_color_acetileno_report   == "success" %>
				Realizar siguiente análisis luego de doce meses ó de acuerdo con el plan de mantenimiento establecido.

				<% else %>
				Realizar siguiente análisis de gases disueltos luego de 6 meses.
				<% if @chromatographical.iec_color_monocarbono_report == "danger" or
				      @chromatographical.iec_color_diocarbono_report  == "danger" or
				      @chromatographical.iec_color_monocarbono_report == "warning" or
				      @chromatographical.iec_color_diocarbono_report  == "warning" %>
				Adicionalmente complementar con el análisis de furanos.
				<% end %>.

				<% end %>

			<% else %>
			  <%= simple_format(@transformer.rec_cro) %>
			<% end %>

  
        </td>         
      </tr>

    </tbody>
  </table>
</div>