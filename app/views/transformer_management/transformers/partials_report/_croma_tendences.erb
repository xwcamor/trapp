    		  	<% if @chromatographical.iec_color_metano_report == "success"%>
    		  	Metano se encuentra en el rango de la Norma IEC 60599. 
    		  	<% end %>
    		  	<% if @chromatographical.iec_color_metano_report == "warning"%>
    		  	<b class="text-warning">Metano se acerca al límite del rango de la Norma IEC 60599. </b>
    		  	<% end %>
    		  	<% if @chromatographical.iec_color_metano_report == "danger"%>
    		  	<b class="text-danger">Metano excede en el rango de la Norma IEC 60599. </b>
    		  	<% end %>	    	
        </p>
      </div>
    </div>        
  </div>
</div>

