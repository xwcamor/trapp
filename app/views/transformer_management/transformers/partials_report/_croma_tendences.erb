<br><br>
<div class="container" >
<div class="row text-center pt-1 pb-0" style="background-color: #E8E8E8" >
  <div class="col-xl-12">
    <b style="font-size: 14px;" > GRÁFICAS DE TENDENCIAS DE GASES DISUELTOS</b> 
  </div>
</div>
</div>

<div class="container" style="font-size: 10px;">
<% @chromatographical_charts = Chromatographical.where("deleted=0 AND transformer_id = #{@transformer.id}").order("date_rehearsal ASC").last(5) %>
 

<div class="row pb-2 text-center">
  <div class="col-6 pt-2">
    <div class="card">
      <div class="card-body border border-dark pb-0 pt-2">    
      	<p><b>Oxígeno</b></p>
      	<p>
          <img width="400" height="120"src="<%= @transformer_graphs.second.code_graph %>?&width=600&height=200&labels=<%= @chromatographical_charts.map { |e| e.str_date_rehearsal }.join(',').html_safe %>&data1=<%= @chromatographical_charts.map { |e| e.num_oxi }.join(',').html_safe %>">
        </p>
      </div>
    </div> 
  </div>
  <div class="col-6 pt-2">
    <div class="card">
      <div class="card-body border border-dark pb-0 pt-2">        
      	<p><b>Nitrógeno</b></p>
      	<p>
          <img width="400" height="120"src="<%= @transformer_graphs.second.code_graph %>?&width=600&height=200&labels=<%= @chromatographical_charts.map { |e| e.str_date_rehearsal }.join(',').html_safe %>&data1=<%= @chromatographical_charts.map { |e| e.num_nit }.join(',').html_safe %>">
        </p>  	
      </div>
    </div>         
  </div>
</div>

<div class="row pb-2 text-center">
  <div class="col-6 pt-2">
    <div class="card">
      <div class="card-body border border-dark pb-0 pt-2">
      	<p class="text-center"><b>Hidrógeno</b><br>
         <i style="font-size: 8px;">Valor Máximo:  <%= @hid_limit_tendence %></i> </p>
      	<p>
          <img width="400" height="120"src="<%= @transformer_graphs.first.code_graph %>?&width=600&height=200&labels=<%= @chromatographical_charts.map { |e| e.str_date_rehearsal }.join(',').html_safe %>&data1=<%= @chromatographical_charts.map { |e| e.num_hid }.join(',').html_safe %>&data2=<%= @hid_limit_tendence %>,<%= @hid_limit_tendence %>,<%= @hid_limit_tendence %>,<%= @hid_limit_tendence %>,<%= @hid_limit_tendence %>">
        </p>
        <p style="font-size: 10px;">
    		  	<% if @chromatographical.iec_color_hidrogeno_report == "success"%>
    		  	Hidrógeno se encuentra en el rango de la Norma IEC 60599. 
    		  	<% end %>
    		  	<% if @chromatographical.iec_color_hidrogeno_report == "warning"%>
    		  	<b class="text-warning">Hidrógeno se acerca al límite del rango de la Norma IEC 60599. </b>
    		  	<% end %>
    		  	<% if @chromatographical.iec_color_hidrogeno_report == "danger"%>
    		  	<b class="text-danger">Hidrógeno excede en el rango de la Norma IEC 60599. </b>
    		  	<% end %>	    
        </p>    
      </div>
    </div>
  </div>
  <div class="col-6 pt-2">
    <div class="card">
      <div class="card-body border border-dark pb-0 pt-2">         
      	<p class="text-center"><b>Metano</b><br>
