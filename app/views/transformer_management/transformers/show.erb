<!DOCTYPE HTML PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN"
  "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html>
  <head>

    <title> Reporte del Transformador</title>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <%#= stylesheet_link_tag  "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"   %>

    <%#= stylesheet_link_tag  "http://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.3.7/css/bootstrap.min.css" %>

  <%#= stylesheet_link_tag  "http://fonts.googleapis.com/css?family=Fira+Sans" %>
  <%#= javascript_tag "https://kit.fontawesome.com/a076d05399.js" %>


  <!--[if lt IE 9]>
  <script src="http://html5shim.googlecode.com/svn/trunk/html5.js"></script>
  <![endif]-->
<%#= stylesheet_link_tag "https://netdna.bootstrapcdn.com/font-awesome/4.0.3/css/font-awesome.css", skip_pipeline: true %>
<%#= wicked_pdf_stylesheet_link_tag "application", media: "all", "data-turbolinks-track" => true %>
 


    <%= wicked_pdf_stylesheet_link_tag "report.css" -%>
    <%#= wicked_pdf_stylesheet_link_tag "iconos.css" -%>
 
     
    

     <style>div.alwaysbreak { page-break-before: always; }</style>

  </head>

  <body>
   
 
   
 
    <div id="info" style="visibility: hiddena"  >

      <!-- BEGIN First Page -->
      <% @count_cromas = @transformer.chromatographicals.where("deleted=0").size %>    
      <% if @count_cromas.to_i > 0 %>    
      <div id="logo2">
        <%= render partial: "transformer_management/transformers/partials_report/main_logo", :locals => {:transformer => @transformer} %>    
      </div>
      <div id="customer_data"> 
        <%= render partial: "transformer_management/transformers/partials_report/customer_data", :locals => {:transformer => @transformer} %> 
      </div>
      <div id="transformer_data">
        <%= render partial: "transformer_management/transformers/partials_report/transformer_data", :locals => {:transformer => @transformer} %>    
      </div>
      <div id="croma_data">
        <%= render partial: "transformer_management/transformers/partials_report/croma_data", :locals => {:transformer => @transformer} %>    
        <div class="alwaysbreak"></div>
      </div>        
      <% end %>    
      <!-- END First Page -->
      
      <div id="croma_tendences">
        <%= render partial: "transformer_management/transformers/partials_report/croma_tendences", :locals => {:transformer => @transformer} %>   
        <div class="alwaysbreak"></div> 
      </div>

      <!-- BEGIN Second Page -->
      <% if @count_cromas.to_i > 0 %>  
      <% if @chromatographical.iec_color_hidrogeno_report   == "success" &&
            @chromatographical.iec_color_metano_report      == "success" &&
            @chromatographical.iec_color_monocarbono_report == "success" &&
            @chromatographical.iec_color_diocarbono_report  == "success" &&
            @chromatographical.iec_color_etileno_report     == "success" &&
            @chromatographical.iec_color_etano_report       == "success" &&
            @chromatographical.iec_color_acetileno_report   == "success" %>
      <% else %>
        <!-- BEGIN DISPLAY DUVALS -->
        <% @count_cromas = @transformer.chromatographicals.where("deleted=0").size %>    
        <% if @count_cromas.to_i > 0 %>    
        <div id="logo">
          <%= render partial: "transformer_management/transformers/partials_report/main_logo", :locals => {:transformer => @transformer} %>    
        </div>
        <div id="customer_data"> 
          <%= render partial: "transformer_management/transformers/partials_report/customer_data", :locals => {:transformer => @transformer} %> 
        </div>
        <div id="transformer_data">
          <%= render partial: "transformer_management/transformers/partials_report/transformer_data", :locals => {:transformer => @transformer} %>    
        </div>
        <div id="duval_data">
          <%= render partial: "transformer_management/transformers/partials_report/duval_data", :locals => {:transformer => @transformer} %>    
          <div class="alwaysbreak"></div>
        </div>        
        <% end %> 
        <!-- END DISPLAY DUVALS -->
      <% end %>  
      <% end %>  
      <!-- End Second Page -->
       
      <!-- BEGIN third Page -->
      <% @count_fiquis = @transformer.physicals.where("deleted=0").size %>    
      <% if @count_fiquis.to_i > 0 %>      
      <div id="logo" >
        <%= render partial: "transformer_management/transformers/partials_report/main_logo", :locals => {:transformer => @transformer} %>    
      </div>
      <div id="customer_data"> 
        <%= render partial: "transformer_management/transformers/partials_report/customer_data", :locals => {:transformer => @transformer} %> 
      </div>
      <div id="transformer_data">
        <%= render partial: "transformer_management/transformers/partials_report/transformer_data", :locals => {:transformer => @transformer} %>    
      </div>
      <div id="fiqui_data">
        <%= render partial: "transformer_management/transformers/partials_report/fiqui_data", :locals => {:transformer => @transformer} %>    
        <div class="alwaysbreak"></div>
      </div>
      <div id="fiqui_tendences">
        <%= render partial: "transformer_management/transformers/partials_report/fiqui_tendences", :locals => {:transformer => @transformer} %>   
        <div class="alwaysbreak"></div> 
      </div>

      <% end %>  
      <!-- End third Page -->
   
      <!-- BEGIN fourth Page -->
      <div id="logo">
        <%= render partial: "transformer_management/transformers/partials_report/main_logo", :locals => {:transformer => @transformer} %>    
      </div>
      <div id="customer_data"> 
        <%= render partial: "transformer_management/transformers/partials_report/customer_data", :locals => {:transformer => @transformer} %> 
      </div>
      <div id="transformer_data">
        <%= render partial: "transformer_management/transformers/partials_report/transformer_data", :locals => {:transformer => @transformer} %>    
      </div>
      <div id="analysis_data">
        <%= render partial: "transformer_management/transformers/partials_report/analysis_data", :locals => {:transformer => @transformer} %>    
        <div class="alwaysbreak"></div>
      </div>
      <!-- End fourth Page -->
   
    </div>
   
  </body>

</html>