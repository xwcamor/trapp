<div class="form-group row m-b-15 text-black">
  <h2>Cliente: <%= @customer.name %></h2>

</div>

<table id="data-table-buttons-filter" class="table table-sm table-hover">
	<thead>
		<tr>
		 
			<th>Ubicación</th>	
			<th>Serie</th>	
			<th>Tag</th>	
			<th>Voltaje</th>
			<th>Potencia</th>
			<th>Marca</th>
			<th>AÑO DE FABRICACION</th>
			<th>TIPO DE ACEITE</th>
			<th>TIPO DE EQUIPO</th>
			<th>TIPO DE CONMUTADOR</th>
			<th>SISTEMA DE EXPANSION</th>
		</tr>
	</thead>

	<tbody>
		<% @list_array.each_with_index do |array,index| %>
		<tr>
 

			<td>
			 

				<% @customer_substation = CustomerSubstation.find_by(deleted: 0, name: array.customer_substation_name, customer_id: params[:customer_id] ) %>

				<% if @customer_substation.present? %>
				  <%= @customer_substation.name %>
				 
				<% else %>
				  <p class="bg-danger text-white" title="No Existe"> Error o No Existe</p><% @error_col="error" %>
				<% end %>				
			</td>

			<td> 
				<% @transformer = Transformer.find_by(deleted: 0, num_serie: array.num_serie ) %>
				<% if @transformer.present? %>
				  <p class="bg-danger text-white" title="Ya Existe"><%= array.num_serie %></p><% @error_col="error" %>
				<% else %>
				  <%= array.num_serie %>
				<% end %>	 

			</td>

			<td><%= array.num_tag %></td>

			<td><%= array.num_vol %></td>

			<td><%= array.num_pot %></td>

			<td> 
				<% @mark = Mark.find_by(deleted: 0, name: array.mark_name) %>

				<% if @mark.present? %>
				  <%= array.mark_name %>
				<% else %>
				  <%= array.mark_name %><p class="bg-danger text-white" title="No Existe">Error</p>
				  <% @error_col="error" %>
				  <% if array.mark_name.strip.empty? or array.mark_name.blank? %>
				    <p class="bg-danger text-white" title="No Existe">Campo Vacio</p><% @error_col="error" %> 
				  <% end %>		          
				<% end %>
			</td>
			<td><%= array.age %></td>
			<td> 
				<% @oil_type = OilType.find_by(deleted: 0, name: array.oil_type_name) %>

				<% if @oil_type.present? %>
				  <%= array.oil_type_name %>
				<% else %>
				  <%= array.oil_type_name %>
				  <p class="bg-danger text-white" title="No Existe">Error</p>
				  <% @error_col="error" %>
				  <% if array.oil_type_name.strip.empty? or array.oil_type_name.blank? %>
				    <p class="bg-danger text-white" title="No Existe">Campo Vacio</p><% @error_col="error" %> 
				  <% end %>	 	      	  
				<% end %>

			</td>
			<td> 
				<% @transformer_type = TransformerType.find_by(deleted: 0, name: array.transformer_type_name) %>

				<% if @transformer_type.present? %>
				  <%= array.transformer_type_name %>
				<% else %>
				  <%= array.transformer_type_name %><p class="bg-danger text-white" title="No Existe">Error</p>
				  <% @error_col="error" %>
				  <% if array.transformer_type_name.strip.empty? or array.transformer_type_name.blank? %>
				    <p class="bg-danger text-white" title="No Existe">Campo Vacio</p><% @error_col="error" %> 
			  	  <% end %>	      	  
				<% end %>	


			</td>
			<td> 
		      	<% @conmutation_type = ConmutationType.find_by(deleted: 0, name: array.conmutation_type_name) %>
		      	<% if @conmutation_type.present? %>
		      	  <%= array.conmutation_type_name %>
		      	<% else %>
		      	  <%= array.conmutation_type_name rescue "" %><p class="bg-danger text-white" title="No Existe">Error</p>
		      	  <% @error_col="error" %>
		      	  <% if array.conmutation_type_name.strip.empty? or array.conmutation_type_name.blank? %>
		      	    <p class="bg-danger text-white" title="No Existe">Campo Vacio</p><% @error_col="error" %> 
		      	  <% end %>	      	  
		      	<% end %>					

			</td>
			<td> 
		      	<% @transformer_preservation = TransformerPreservation.find_by(deleted: 0, name: array.transformer_preservation_name) %>
		      	<% if @transformer_preservation.present? %>
	  	      	    <%= array.transformer_preservation_name %>
		      	<% else %>
		      	  <%= array.transformer_preservation_name %><p class="bg-danger text-white" title="No Existe">Error</p>
		      	  <% @error_col="error" %>
		      	  <% if array.transformer_preservation_name.strip.empty? or array.transformer_preservation_name.blank? %>
		      	    <p class="bg-danger text-white" title="No Existe">Campo Vacio</p><% @error_col="error" %> 
		      	  <% end %>
		      	<% end %>					

			</td>
		</tr>
		<% end%>
	</tbody>
</table>


<% if @list_array.size  > 0%>
  <a <% if @error_col.present? %><%else %>href="/transformer_management/import_transformers/step4?customer_id=<%= @customer.id %>&user_id=<%= current_user.id %>"<%end %> id="button_save" class="btn btn-primary"   type="button"  >
    <i class="fa-solid fa-check-double"></i> Continuar Proceso
  </a>  

  <% end %>