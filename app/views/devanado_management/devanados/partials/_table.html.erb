<%= flash_messages %>
<table id="data-table-buttons-filter" class="table table-bordered table-hover">
  <thead>

    <tr class="text-center">
      <th>Fecha</th>
      <% @template_selected = DevanadoTemplateTransformer.find_by_transformer_id(@transformer.id) %>
      <% @template = DevanadoTemplate.find(@template_selected.devanado_template_id) %>
      <% @template.devanado_template_details.where("devanado_flow_id = 1").each do |a| %>
      <th><%= a.name %><br><%= a.devanado_template.unit_name%></th>
      <% end%>
      <% @template.devanado_template_details.where("devanado_flow_id = 2").each do |a| %>
      <th><%= a.name %><br><%= a.devanado_template.unit_name%></th>
      <% end%>
      <% @template.devanado_template_details.where("devanado_flow_id = 3").each do |a| %>
      <th><%= a.name %><br><%= a.devanado_template.unit_name%></th>
      <% end%>
      <% @template.devanado_template_details.where("devanado_flow_id = 4").each do |a| %>
      <th><%= a.name %><br><%= a.devanado_template.unit_name%></th>
      <% end%>                  
 
      <th data-orderable="false" class="sorting_disabled">Acciones</th>  
    </tr>    
    <tr class="text-center filter_row">
      <th>Fecha</th>
      <% @template_selected = DevanadoTemplateTransformer.find_by_transformer_id(@transformer.id) %>
      <% @template = DevanadoTemplate.find(@template_selected.devanado_template_id) %>
      <% @template.devanado_template_details.where("devanado_flow_id = 1").each do |a| %>
      <th><%= a.name %> </th>
      <% end%>
      <% @template.devanado_template_details.where("devanado_flow_id = 2").each do |a| %>
      <th><%= a.name %>  </th>
      <% end%>
      <% @template.devanado_template_details.where("devanado_flow_id = 3").each do |a| %>
      <th><%= a.name %>  </th>
      <% end%>
      <% @template.devanado_template_details.where("devanado_flow_id = 4").each do |a| %>
      <th><%= a.name %> </th>
      <% end%>                  
      <td></td>
    </tr>    
  </thead>
  <tbody>
 
    <% @calculation.each do |devanado_detail| %>  
    <tr class="text-center">
      <td data-sort='<%= devanado_detail.date_devanado %>'><%= devanado_detail.date_devanado %></td>
      <td><%= devanado_detail.dif_at_1 %>  <br>(<%= devanado_detail.per_at_1 %>  %)</td>
      <td><%= devanado_detail.dif_at_2 %>  <br>(<%= devanado_detail.per_at_2 %>  %)</td>
      <td><%= devanado_detail.dif_at_3 %>  <br>(<%= devanado_detail.per_at_3 %>  %)</td>
      <td><%= devanado_detail.dif_bt1_1 %> <br>(<%= devanado_detail.per_bt1_1 %> %)</td>
      <td><%= devanado_detail.dif_bt1_2 %> <br>(<%= devanado_detail.per_bt1_2 %> %)</td>
      <td><%= devanado_detail.dif_bt1_3 %> <br>(<%= devanado_detail.per_bt1_3 %> %)</td>       
      <td><%= devanado_detail.dif_bt2_1 %> <br>(<%= devanado_detail.per_bt2_1 %> %)</td>
      <td><%= devanado_detail.dif_bt2_2 %> <br>(<%= devanado_detail.per_bt2_2 %> %)</td>
      <td><%= devanado_detail.dif_bt2_3 %> <br>(<%= devanado_detail.per_bt2_3 %> %)</td>       
      <td><%= devanado_detail.dif_bt3_1 %> <br>(<%= devanado_detail.per_bt3_1 %> %)</td>
      <td><%= devanado_detail.dif_bt3_2 %> <br>(<%= devanado_detail.per_bt3_2 %> %)</td>
      <td><%= devanado_detail.dif_bt3_3 %> <br>(<%= devanado_detail.per_bt3_3 %> %)</td>  
 
      <td>
        <div class="widget-list-action">
          <a href="#" data-bs-toggle="dropdown" class="text-gray-500" aria-expanded="false"><i class="fa fa-ellipsis-h fs-14px"></i></a>
          <div class="dropdown-menu dropdown-menu-end" style="">  
            <% if @user_permission.include?(59) %>
            <%=link_to "<i class='fa-solid fa-eye'></i> Ver Prueba".html_safe, devanado_management_transformer_devanado_path(@transformer,devanado_detail.devanado_id), class: "dropdown-item", title: "Editar"%>
            <% end %>            
            <% if @user_permission.include?(59) %>
            <%=link_to "<i class='fa fa-pencil'></i> Editar Prueba".html_safe, edit_devanado_management_transformer_devanado_path(@transformer,devanado_detail.devanado_id), class: "dropdown-item", title: "Editar"%>
            <% end %>
            <div class="dropdown-divider"></div>
            <% if @user_permission.include?(60) %>
            <%= link_to "<i class='fa-solid fa-trash'></i> Eliminar Prueba".html_safe,devanado_management_transformer_devanado_delete_path(@transformer,devanado_detail.devanado_id) ,{ class: "dropdown-item bg-danger text-white", title: "Eliminar"} %>
            <% end %>                    
          </div>
        </div>                  
      </td>                       
    </tr> 
    <% end %>                   
  </tbody>
  <tfoot>
    <tr class="text-center">
      <th>Fecha</th>
      <th colspan="3">AT</th>
      <th colspan="3">BT1</th>
      <th colspan="3">BT2</th>
      <th colspan="3">BT3</th>                 
      <th data-orderable="false" class="sorting_disabled">Acciones</th>  
    </tr>    

  </tfoot>
   
</table>       