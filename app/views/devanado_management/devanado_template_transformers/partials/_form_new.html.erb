<%= form_for [:devanado_management, @devanado_template_transformer],:html=>{'data-parsley-validate'=>"true", :autocomplete=>"off" } do |f| %> 
 
<%= f.hidden_field :transformer_id,:value =>@transformer.id  %>
<!-- begin row -->
<div class="row">
  <!-- begin col-6 -->
  <div>
    <!-- begin panel -->
    <div class="panel panel-inverse border">
      <!-- begin panel-heading -->
      <div class="panel-heading">
        <h4 class="panel-title">Template para la Resistencia de Devanado
        </h4>
        <%= render :partial =>"layouts/panel_heading" %>
      </div>
      <!-- end panel-heading -->
      <!-- begin panel-body -->
      <div class="panel-body">
        <div class="table-responsive">
        <table  class="table table-hover align-middle table-bordered">
          <thead>
            <tr class="text-center">
              <th colspan="3"> </th>
      			  <th colspan="3">AT</th>
      			  <th colspan="3">BT1</th>
      			  <th colspan="3">BT2</th>
      			  <th colspan="3">BT3</th>			  
            </tr>
            <tr class="text-center">
              <th>Seleccionar </th>
              <th>Template </th>
              <th>Unidad de Medida </th>
      			  <th>Título 1</th>
      			  <th>Título 2</th>
      			  <th>Título 3</th>
      			  <th>Título 1</th>
      			  <th>Título 2</th>
      			  <th>Título 3</th>
      			  <th>Título 1</th>
      			  <th>Título 2</th>
      			  <th>Título 3</th>
      			  <th>Título 1</th>
      			  <th>Título 2</th>
      			  <th>Título 3</th>			
              <th></th>  			  			  
            </tr>            
          </thead>
          <tbody>
    		   <% @devanado_templates.each do |devanado_template| %>
    		   <tr class="text-center">
    		     <td><%= f.radio_button :devanado_template_id, devanado_template.id ,"data-parsley-required"=>"true" %></td>
    		     <td><%= devanado_template.name %></td>
             <td><%= devanado_template.unit_name %></td>
    		     <% devanado_template.devanado_template_details.each do |devanado_template_detail| %>
    		     <td><%= devanado_template_detail.name %></td>
    		     <% end %>
             <td>
              <% if devanado_template.id == 1 %>
              <% else %>
              <%= link_to "<i class='fa-solid fa-pencil'></i>".html_safe, edit_devanado_management_transformer_devanado_template_path(@transformer,devanado_template) ,{:title=>"Editar",:class=>"btn btn-xs btn-default"} %>
              <% end %>
             </td>
    		   </tr>  
    		  <% end %>                 
          </tbody>
        </table>     
        </div>

	    <br>
	    <div class="text-center me-1 mb-3">
          <%= link_to "<i class='fa-solid fa-left'></i> Regresar a Pruebas Eléctricas".html_safe, electrical_management_transformer_electricals_path(@transformer), class: "btn btn-gray  me-1 mb-3  rounded-pill" %> 
          <%= button_tag( :class => "btn btn-gray  me-1 mb-3 rounded-pill") do %>
               <i class='fa fa-floppy-disk'></i> Usar Template
          <% end %> 
          <%= link_to "<i class='fa-solid fa-plus'></i> Crear Template".html_safe, new_devanado_management_transformer_devanado_template_path(@transformer), class: "btn btn-gray  me-1 mb-3  rounded-pill" %> 
                   
	    </div>  

      </div>
      <!-- end panel-body -->
    </div>
    <!-- end panel -->
  </div>
  <!-- end col-6 -->

 
</div>
<!-- end row -->

<% end %>