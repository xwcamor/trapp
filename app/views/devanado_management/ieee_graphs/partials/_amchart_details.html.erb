<!-- Styles -->
<style>
#chart_1 {
  width: 100%;
  height: 550px;
  max-width: 100%;
}
</style>

<!-- Resources -->
 
<!-- Chart code -->
<script>
am5.ready(function func_main() {
am5.addLicense('<%= amchart_license %>');

// Create root element
// https://www.amcharts.com/docs/v5/getting-started/#Root_element 
var root = am5.Root.new("chart_1");

var exporting = am5plugins_exporting.Exporting.new(root, {
  menu: am5plugins_exporting.ExportingMenu.new(root, {})
});
 
// Set themes
// https://www.amcharts.com/docs/v5/concepts/themes/ 
root.setThemes([
  am5themes_Animated.new(root)
]);

// Set Traslattion
// https://www.amcharts.com/docs/v5/concepts/locales/creating-translations/#Getting_started
 

// Create chart
// https://www.amcharts.com/docs/v5/charts/xy-chart/
var chart = root.container.children.push(am5xy.XYChart.new(root, {
  panX: true,
  panY: true,
  wheelX: "panX",
  wheelY: "zoomX" 
}));
 
// Create axes
// https://www.amcharts.com/docs/v5/charts/xy-chart/axes/
var xAxis = chart.xAxes.push(am5xy.DateAxis.new(root, {
  maxDeviation: 0.5,
  groupData: false,
  extraMax:0.1, // this adds some space in front
  extraMin:-0.1,  // this removes some space form th beginning so that the line would not be cut off
  baseInterval: {
    timeUnit: "minute",
    count: 1
  },

  renderer: am5xy.AxisRendererX.new(root, {
    minGridDistance: 50
  }),
  tooltip: am5.Tooltip.new(root, {})
}));

var yAxis = chart.yAxes.push(am5xy.ValueAxis.new(root, {
   maxDeviation:1,
   numberFormat: "#  'U.M '",
   tooltipNumberFormat: "#'%'",  
   renderer: am5xy.AxisRendererY.new(root, {})
}));


xAxis.get("dateFormats")["hour"] = "h";
xAxis.get("dateFormats")["minute"] = "m";
xAxis.get("periodChangeDateFormats")["day"] = "MMMM";
// Add series
// https://www.amcharts.com/docs/v5/charts/xy-chart/series/

<% @devanados.each do |e| %> 
  var series<%= e.id %> = chart.series.push(am5xy.SmoothedXLineSeries.new(root, {
  name: "RS (<%= e.str_date_rehearsal %>)" ,
  xAxis: xAxis,
  yAxis: yAxis,
  valueYField: "value",
  valueXField: "date",
  minDistance: 0,
  legendValueText: "{valueY}",
  tooltip: am5.Tooltip.new(root, {
    pointerOrientation: "horizontal",
    labelText: "RS (<%= e.str_date_rehearsal %>) = {valueY} "
  })
}));
<% end %>


<% @devanados.each do |e| %> 
  var series2<%= e.id %> = chart.series.push(am5xy.SmoothedXLineSeries.new(root, {
  name: "ST (<%= e.str_date_rehearsal %>)" ,
  xAxis: xAxis,
  yAxis: yAxis,
  valueYField: "value",
  valueXField: "date",
  minDistance: 0,
  legendValueText: "{valueY}",
  tooltip: am5.Tooltip.new(root, {
    pointerOrientation: "vertical",
    labelText: "ST (<%= e.str_date_rehearsal %>) = {valueY} "
  })
}));
<% end %>
 
<% @devanados.each do |e| %> 
  var series3<%= e.id %> = chart.series.push(am5xy.SmoothedXLineSeries.new(root, {
  name: "TR (<%= e.str_date_rehearsal %>)" ,
  xAxis: xAxis,
  yAxis: yAxis,
  valueYField: "value",
  valueXField: "date",
  minDistance: 0,
  legendValueText: "{valueY}",
  tooltip: am5.Tooltip.new(root, {
    pointerOrientation: "horizontal",
    labelText: "TR (<%= e.str_date_rehearsal %>) = {valueY} "
  })
}));
<% end %>
  

<% @devanados.each do |e| %>
var data_gases<%= e.id %> = [
   <% @devanado_details.where("devanado_flow_id = 1 AND date_devanado = ?",e.date_rehearsal).order("id ASC").each_with_index do |a,index| %>               
   { 
      date: new Date(2023,1,1, 0, <%= index + 1  %>, 0).getTime(),
      value: <%= a.col1_val %>
    },
    <% end %>
]   
<% end %>

<% @devanados.each do |e| %>
var data_gases2<%= e.id %> = [
   <% @devanado_details.where("devanado_flow_id = 1 AND date_devanado = ?",e.date_rehearsal).order("id ASC").each_with_index do |a,index| %>               
   { 
      date: new Date(2023,1,1, 0, <%= index + 1  %>, 0).getTime(),
      value: <%= a.col2_val %>
    },
    <% end %>
]   
<% end %>
 

<% @devanados.each do |e| %>
var data_gases3<%= e.id %> = [
   <% @devanado_details.where("devanado_flow_id = 1 AND date_devanado = ?",e.date_rehearsal).order("id ASC").each_with_index do |a,index| %>               
   { 
      date: new Date(2023,1,1, 0, <%= index + 1  %>, 0).getTime(),
      value: <%= a.col3_val %>
    },
    <% end %>
]   
<% end %>
 
//  
 
<% @devanados.each do |e| %> 
  series<%= e.id %>.data.setAll(data_gases<%= e.id %>);
  series<%= e.id %>.bullets.push(function() {
    return am5.Bullet.new(root, {
      locationY: 0,
      sprite: am5.Circle.new(root, {
        radius: 3,
        stroke: root.interfaceColors.get("background"),
        strokeWidth: 0,
        fill: series<%= e.id %>.get("fill")
      })
    });
  });
<% end %>


<% @devanados.each do |e| %> 
  series2<%= e.id %>.data.setAll(data_gases2<%= e.id %>);
  series2<%= e.id %>.bullets.push(function() {
    return am5.Bullet.new(root, {
      locationY: 0,
      sprite: am5.Circle.new(root, {
        radius: 3,
        stroke: root.interfaceColors.get("background"),
        strokeWidth: 0,
        fill: series2<%= e.id %>.get("fill")
      })
    });
  });
<% end %>

<% @devanados.each do |e| %> 
  series3<%= e.id %>.data.setAll(data_gases3<%= e.id %>);
  series3<%= e.id %>.bullets.push(function() {
    return am5.Bullet.new(root, {
      locationY: 0,
      sprite: am5.Circle.new(root, {
        radius: 3,
        stroke: root.interfaceColors.get("background"),
        strokeWidth: 0,
        fill: series3<%= e.id %>.get("fill")
      })
    });
  });
<% end %>

 
 
// Add cursor
// https://www.amcharts.com/docs/v5/charts/xy-chart/cursor/
var cursor = chart.set("cursor", am5xy.XYCursor.new(root, {
  behavior: "none"
}));
cursor.lineY.set("visible", false);




// Add scrollbar
// https://www.amcharts.com/docs/v5/charts/xy-chart/scrollbars/
chart.set("scrollbarX", am5.Scrollbar.new(root, {
  orientation: "horizontal"
}));

chart.set("scrollbarY", am5.Scrollbar.new(root, {
  orientation: "vertical"
}));

// Add legend
// https://www.amcharts.com/docs/v5/charts/xy-chart/legend-xy-series/
var legend = chart.rightAxesContainer.children.push(am5.Legend.new(root, {
  width: 200,
  paddingLeft: 15,
  height: am5.percent(100)
}));

// When legend item container is hovered, dim all the series except the hovered one
legend.itemContainers.template.events.on("pointerover", function(e) {
  var itemContainer = e.target;

  // As series list is data of a legend, dataContext is series
  var series = itemContainer.dataItem.dataContext;

  chart.series.each(function(chartSeries) {
    if (chartSeries != series) {
      chartSeries.strokes.template.setAll({
        strokeOpacity: 0.15,
        stroke: am5.color(0x00000)
      });
    } else {
      chartSeries.strokes.template.setAll({
        strokeWidth: 3
      });
    }
  })
})

// When legend item container is unhovered, make all series as they are
legend.itemContainers.template.events.on("pointerout", function(e) {
  var itemContainer = e.target;
  var series = itemContainer.dataItem.dataContext;

  chart.series.each(function(chartSeries) {
    chartSeries.strokes.template.setAll({
      strokeOpacity: 1,
      strokeWidth: 1,
      stroke: chartSeries.get("fill")
    });
  });
})

legend.itemContainers.template.set("width", am5.p100);
legend.valueLabels.template.setAll({
  width: am5.p100,
  textAlign: "right"
});

// It's is important to set legend data after all the events are set on template, otherwise events won't be copied
legend.data.setAll(chart.series.values);

}); // end am5.ready()
</script>

<!-- HTML -->
<div id="chart_1"  class="bg-white"></div>
