<div class="row">               
    <div class="table-responsive">
      <table id="devanado_details_r1" class="table table-hover align-middle table-bordered">
        <thead>
          <tr class="text-center">
            <th colspan="3">AT</th>
            <th colspan="3">BT 1</th>
            <th colspan="3">BT 2</th>
            <th colspan="3">BT 3</th>            
          </tr>          
          <tr class="text-center">
            <th>Nombre 1</th>
            <th>Nombre 2</th>
            <th>Nombre 3</th>
            <th>Nombre 1</th>
            <th>Nombre 2</th>
            <th>Nombre 3</th>
            <th>Nombre 1</th>
            <th>Nombre 2</th>
            <th>Nombre 3</th>
            <th>Nombre 1</th>
            <th>Nombre 2</th>
            <th>Nombre 3</th>
          </tr>
        </thead>
        <tbody>
          <tr class="fields">
           <%= f.fields_for :devanado_template_details, f.object.devanado_template_details.where('devanado_flow_id = 1 AND devanado_template_id =?',@devanado_template.id) , :wrapper => false do |nested_form| %>
            <%= nested_form.hidden_field :devanado_flow_id, value: 1 %>
            <td><%= nested_form.text_field :name, class: 'form-control text-center' ,'data-parsley-required'=>"false",placeholder: "Digitar Valor" %></td>
           <% end %>   
           <%= f.fields_for :devanado_template_details, f.object.devanado_template_details.where('devanado_flow_id = 2 AND devanado_template_id =?',@devanado_template.id) , :wrapper => false do |nested_form| %>
            <%= nested_form.hidden_field :devanado_flow_id, value: 2 %>
            <td><%= nested_form.text_field :name, class: 'form-control text-center' ,'data-parsley-required'=>"false",placeholder: "Digitar Valor" %></td>
           <% end %>    
           <%= f.fields_for :devanado_template_details, f.object.devanado_template_details.where('devanado_flow_id =3 AND devanado_template_id =?',@devanado_template.id) , :wrapper => false do |nested_form| %>
            <%= nested_form.hidden_field :devanado_flow_id, value: 3 %>
            <td><%= nested_form.text_field :name, class: 'form-control text-center' ,'data-parsley-required'=>"false",placeholder: "Digitar Valor" %></td>
           <% end %>    
           <%= f.fields_for :devanado_template_details, f.object.devanado_template_details.where('devanado_flow_id =4 AND devanado_template_id =?',@devanado_template.id) , :wrapper => false do |nested_form| %>
            <%= nested_form.hidden_field :devanado_flow_id, value: 4 %>
            <td><%= nested_form.text_field :name, class: 'form-control text-center' ,'data-parsley-required'=>"false",placeholder: "Digitar Valor" %></td>
           <% end %>                                  
          </tr>
        </tbody>
      </table>
    </div>
</div> 