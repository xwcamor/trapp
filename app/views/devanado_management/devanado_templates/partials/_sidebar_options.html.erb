  <%= link_to "<i class='fa fa-award'></i> Templates".html_safe, {:controller=>"devanado_management/devanado_flows",:action=>"index",:id=>params[:id] }, { class: "btn btn-default w-100 mb-2 text-start" }   %>    
  <% end %>                       
