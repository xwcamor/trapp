              <td class="text-nowrap text-center">Limite</td>
              <td class="text-nowrap text-center"><i class="fa-solid fa-syringe"></i>></td>
              <td class="text-nowrap text-center"><i class="fa-solid fa-syringe"></i></td>
              <td class="text-nowrap text-start"><%= chromatographical.iec_color_hidrogeno rescue ""  %> <%= chromatographical.iec_hidrogeno  rescue ""%> </td>
