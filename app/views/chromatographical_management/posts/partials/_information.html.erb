              <td class="text-nowrap text-start"><%= chromatographical.iec_color_monocarbono rescue ""  %> <%= chromatographical.iec_monocarbono  rescue ""%> </td>
              <td class="text-nowrap text-start"><%= chromatographical.iec_color_diocarbono rescue ""  %> <%= chromatographical.iec_diocarbono  rescue ""%> </td>
              <td class="text-nowrap text-start"><%= chromatographical.iec_color_etileno rescue ""  %> <%= chromatographical.iec_etileno  rescue ""%> </td>
              <td class="text-nowrap text-start"><%= chromatographical.iec_color_etano rescue ""  %> <%= chromatographical.iec_etano  rescue ""%> </td>
              <td class="text-nowrap text-start"><%= chromatographical.iec_color_acetileno rescue ""  %> <%= chromatographical.iec_acetileno rescue ""%> </td>
              <td class="text-nowrap text-center">Norma IEC</td>              
            </tr>    
            <% end %>       
            <% @chromatographicals.each do |chromatographical| %>
            <tr>
              <td class="text-nowrap text-center">Límite</td>
              <td class="text-nowrap text-center"><i class="fa-solid fa-syringe"></i></td>
              <td class="text-nowrap text-center"><i class="fa-solid fa-syringe"></i></td>
              <td class="text-nowrap text-start"><%= chromatographical.ieee_color_hidrogeno rescue "" %> <%= chromatographical.ieee_hidrogeno_tabla1 %></td>
              <td class="text-nowrap text-start"><%= chromatographical.ieee_color_metano rescue "" %> <%= chromatographical.ieee_metano_tabla1 %></td>
              <td class="text-nowrap text-start"><%= chromatographical.ieee_color_monocarbono rescue "" %> <%= chromatographical.ieee_monocarbono_tabla1 %></td>
              <td class="text-nowrap text-start"><%= chromatographical.ieee_color_diocarbono rescue "" %> <%= chromatographical.ieee_diocarbono_tabla1 %></td>
              <td class="text-nowrap text-start"><%= chromatographical.ieee_color_etileno rescue "" %> <%= chromatographical.ieee_etileno_tabla1 %></td>
              <td class="text-nowrap text-start"><%= chromatographical.ieee_color_etano rescue "" %> <%= chromatographical.ieee_etano_tabla1 %></td>
              <td class="text-nowrap text-start"><%= chromatographical.ieee_color_acetileno rescue "" %> <%= chromatographical.ieee_acetileno_tabla1 %></td>
              <td class="text-nowrap text-center">Norma IEE</td>              
            </tr>    
            <% end %>                   
          </tbody>
        </table>   