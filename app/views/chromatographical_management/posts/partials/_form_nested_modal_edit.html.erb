<table  id="comments" class="table table-hover">
  <%= f.fields_for :comments, f.object.comments.where('user_id =?',current_user.id) , :wrapper => false do |nested_form| %>
    <tr class="fields mb-3">
      <td valign="middle">
          <% if current_user.avatar_url %>
            <img src="<%= current_user.avatar_url %>" height="35" class="rounded-pill">
          <% else %>
            <i class="fa fa-user text-black ms-1 " aria-hidden="true"></i>
          <% end %>
      </td>
      <td valign="middle">
        <span class="badge bg-danger ms-1 py-2px position-relative" style="top: -1px;">Importante</span> <%= nested_form.check_box :rate %>
      </td>        
      <td valign="middle">
        <%= nested_form.hidden_field :user_id ,:value=> current_user.id %>
        <div class="position-relative">
          <%= nested_form.text_area :description, class: 'form-control rounded-pill ps-3 py-2 fs-13px bg-light','data-parsley-required'=>"true" %>
        </div>
      </td>
      <td valign="middle"><%= nested_form.link_to_remove "<i class='fa-solid fa-trash text-dark shadow-none px-1'></i>".html_safe %></td>
    </tr>
  <% end %>
</table>