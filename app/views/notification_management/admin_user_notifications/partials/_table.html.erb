<table id="data-table-buttons1" class="table table-striped align-middle">
  <thead>
    <tr>
      <th class="text-nowrap text-center"><%= sort_link(@query, :transformer_id,'Serie del Transformador', default_order:  { transformer_id: 'desc' }) %></th>
      <th class="text-nowrap text-center"><%= sort_link(@query, :description,'Descripciòn', default_order:  { description: 'desc' }) %></th>
      <th class="text-nowrap text-center"><%= sort_link(@query, :state,'Estado', default_order:  { state: 'desc' }) %></th>
      <th data-orderable="false" class="sorting_disabled"> </th>             
    </tr>
  </thead>
  <tbody>
    <% @list_user_notifications.each do |user_notification| %>
    <tr>
      <td class="text-center"><%= user_notification.transformer.num_serie %></td>  
      <td class="text-center"><%= user_notification.description %></td>   
      <td class="text-center"><%= user_notification.str_state %></td>    
      <td>
        <% if @user_permission.include?(25) %>
        <%= link_to "<i class='fa-solid fa-eye'></i>".html_safe,{:controller=>"notification_management/user_notifications",:action=>"show",:id=>user_notification} ,{ class: "btn btn-xs btn-default", title: "Ver"} %>
        <% end %>
        
        <% if @user_permission.include?(27) %>
        <%= link_to "<i class='fa fa-pencil'></i>".html_safe, edit_notification_management_user_notification_path(user_notification), class: "btn btn-xs btn-default", title: "Editar"%>
        <% end %>

        <% if @user_permission.include?(28) %>
        <%= link_to "<i class='fa-solid fa-trash'></i>".html_safe,{:controller=>"notification_management/user_notifications",:action=>"destroy",:id=>user_notification} ,{  method: :delete,  class: "btn btn-xs btn-default", title: "Eliminar"} %>
        <% end %>
       
      </td>                   
    </tr>
    <% end %>                  
  </tbody>
</table>

 
<div style="float:right">
  <%= will_paginate(@list_user_notifications, :params => params,  :constainer=>true, :previous_label=>"<i class='fa fa-arrow-left'></i>", :next_label=>"<i class='fa fa-arrow-right'></i>",inner_window: 1, outer_window: 1 ,:renderer => WillPaginate::ActionView::Bootstrap4LinkRenderer , class: 'pagination-sm ') %>
</div> 
<style>
 .page-item.active .page-link {
   color: #fff !important;
   background: gray !important;
 }
</style> 