<% title "Notificaciones" %>
 
<div class="panela">
  <!-- begin panel-body -->
  <div class="panel-body">
    <h4 class="page-header">
    <i class="fa-solid fa-bell"></i> Notificaciones
    </h4>
  </div>
  <!-- end panel-body -->
</div>
<!-- end panel -->
 

  <hr>

<!-- begin row -->
<div class="row">
  <% @user_notifications.each do |user_notification| %>
  <!-- begin col-10 -->
  <div class="col-xl-12 ">
    <!-- begin panel -->
    <div class="panel panel-inverse border">
      <!-- begin panel-heading -->
      <div class="panel-heading bg-gray-800 text-white">
        <h4 class="panel-title">Notificaciones</h4>
        <%= render :partial =>"layouts/panel_heading" %>
      </div>
      <!-- end panel-heading -->
 
      <!-- begin panel-body -->
      <div class="panel-body">
         <%= user_notification.description.html_safe %>              
         
      </div>
      <!-- end panel-body -->
    </div>
    <!-- end panel -->
  </div>
  <!-- end col-10 -->
  <% end %>
</div>
<!-- end row -->
 

<%= render :partial =>"layouts/app_bottom_script" %>