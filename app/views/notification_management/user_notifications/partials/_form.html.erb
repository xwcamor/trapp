<%= form_for [:notification_management, @user_notification],:html=>{'data-parsley-validate'=>"true", :class=>"form-bordered",:autocomplete=>"off"} do |f| %> 

<!-- begin alert --> 
<% if @user_notification.errors.any? %>
<div class="note note-gray">
  <div class="note-icon"><i class="ion-md-alert"></i></div>
  <div class="note-content">
    <h4><b>Se encontraron los siguientes errores:</b></h4>
    <% @user_notification.errors.each do |error| %>
      <i class="ion-md-alert"></i> <%= error.message %><br>
    <% end %>
  </div>
</div>  
<% end %>
<!-- end alert -->   
<br> 
<!-- begin panel -->
<div class="panela">
  <!-- begin panel-body -->
  <div class="panel-body">
    <h2 class="page-header"><i class="fa-solid fa-bell"></i> Notificaciones</h2>
    <hr>

    <br><br>
    <!-- begin row-->
    <div class="row">
      <!-- begin col-3 -->
      <div class="col-md-12">
        <div class="form-group row m-b-15">
          <label class="col-md-3 col-sm-4 col-form-label">Fecha</label>
          <div class="col-md-9 col-sm-8">
             <%= f.date_field :date_notification, class: 'form-control','data-parsley-required'=>"true"  %>
          </div>
        </div>
      </div>
      <!-- end col-3 -->
    </div>
    <!-- end row-->

    <br><br>
      <!-- begin row -->
      <div class="row">
        <!-- begin col4 -->
        <div class="col-md-12">
          <div class="form-group row m-b-15">
              <label class="col-md-3 col-sm-4 col-form-label">Usuario</label>
              <div class="col-md-9 col-sm-8">
                <%# if @condicion > 1 %>
                 <%= f.select :user_id, @users.map { |t| [t.str_complete_name , t.id] }, {}, class: "default-select form-select"  %>
                  <%#= select_tag "search_customer" , "<option value=\"\">Seleccione</option>".html_safe+options_for_select(@user_customers.collect { |p| [p.customer.name,p.customer_id.to_s] }, params[:search_customer].to_i )  , class: "form-select",'data-parsley-required'=>"true" %>
                <%# else  %>
                  <%#= f.select :user_id, @user_customers.map { |t| [t.customer.name, t.customer_id] }, {}, class: "default-select form-select"  %>
                  <%#= select_tag "search_customer","<option value=\"\">Seleccione</option>".html_safe+ options_for_select(@user_customers.collect { |p| [p.customer.name,p.customer_id.to_s] }, params[:search_customer].to_i ) , :'data-remote' => 'true', :'data-url' => url_for( :action => 'update_location_form') , class: "form-select",'data-parsley-required'=>"true" %>
                <%# end %>
              </div>
          </div>   
        </div>    
        <!-- end col4 -->
               
      </div>
      <!-- end row -->

    <br><br>
    <!-- begin row-->
    <div class="row">
      <!-- begin col-3 -->
      <div class="col-md-12">
        <div class="form-group row m-b-15">
          <label class="col-md-3 col-sm-4 col-form-label">Transformador</label>
          <div class="col-md-9 col-sm-8">
             <%= f.select :transformer_id, @transformers.map { |t| [t.num_serie, t.id] }, {}, class: "default-select form-select"  %>
          </div>
        </div>
      </div>
      <!-- end col-3 -->
    </div>
    <!-- end row-->

    <br><br>
    <!-- begin row-->
    <div class="row">
      <!-- begin col-3 -->
      <div class="col-md-12">
        <div class="form-group row m-b-15">
          <label class="col-md-3 col-sm-4 col-form-label">Descripción</label>
          <div class="col-md-9 col-sm-8">
             <%= f.text_area :description, class: 'form-control','data-parsley-required'=>"true"  %>
          </div>
        </div>
      </div>
      <!-- end col-3 -->
    </div>
    <!-- end row-->
     
    <br><br>
    <!-- begin row-->
    <div class="row">
      <!-- begin col-3 -->
      <div class="col-md-12">
        <div class="form-group row m-b-15">
          <label class="col-md-3 col-sm-4 col-form-label">Estado</label>
          <div class="col-md-9 col-sm-8">
             <%= f.select :state, [["Activo",0],["Inactivo",1]],{},class: "form-control" %>             
          </div>
        </div>
      </div>
      <!-- end col-3 -->
      
                                
    </div>
    <!-- end row-->
      <br>
      <div class="text-center me-1 mb-3">
        <%= link_to "<i class='fa fa-arrow-left'></i> Regresar a Notificaciones".html_safe, [:notification_management,:user_notifications], class: "btn btn-gray  me-1 mb-3  rounded-pill" %> 
 
            <%= button_tag( :class => "btn btn-gray  me-1 mb-3 rounded-pill") do %>
               <i class='fa-solid fa-floppy-disk'></i> Guardar Notificación
            <% end %>
          
       </div>  

  </div>
  <!-- end panel-body -->
</div>
<!-- end panel --> 
<% end %>
