<%= javascript_include_tag "application" %>
 

 
<link href="/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet" />
<script src="/assets/plugins/select2/dist/js/select2.min.js"></script>


 
<div>
  <label>Seleccione Serie de Transformador</label>
  <select id="transformers"  name="transformer_id" style="width: 300px"></select>
</div>

<%#= link_to "Message", update_div_json_management_lab_registries_transformers_path(:transformer_id => 1,:format => :js ), :remote => true ,:id=>"myCheck"%>
 
<div id="div_content">No hay datos</div>
  

<script>
  function formatResult (state) {
    if (!state.id) { return state.text; }

    var baseUrl = "/json_management/lab_registries/transformers/update_div.js?transformer_id";
    var $state = $(
      '<div id="main"><a id="'+ state.id +'" data-remote="true"></a><div id="result_selected"></div></div>'
    );

    // Use .text() instead of HTML string concatenation to avoid script injection issues
    $state.find("div").text(state.text);
    $state.find("a").attr("href", baseUrl + "=" + state.element.value.toLowerCase()  );

    return $state;
  };

  $("#transformers").select2({
    //allowClear: true,
    minimumInputLength: 1,
    language: { 
      inputTooShort: function() { return 'Digite 1 letra'; },
      noResults: function(){return "No hay resultados"; }
    },   
    dataType: 'json',
    ajax: {
      url: '/json_management/lab_registries/transformers/search',
        delay: 250,
        data: function (params) {
          var query = {
            //search: params.term,
            num_serie: params.term,
            //type: 'public'
          }
          // Query parameters will be ?search=[term]&type=public
          return query;
        },        
        processResults: function (data, params) {
          return {
            results: $.map(data, function(value, index){
              return { 
                id: value.id,
                text: value.num_serie  };
            })
          };
        }
    },
    placeholder: 'Seleccione una opción',    
    templateSelection: formatResult 
  });

  //$("#transformers").on('change', function(e) {
    // Access to full data
  //  console.log($(this).select2('data'));
  //});

  $('#transformers').on("select2:select", function(e) { 
    // what you would like to happen
    var data = e.params.data.id;
    //alert("Se esta seleccionando el id "+ data);
    //console.log(data);    
    document.getElementById(data).click();
  });
 
</script>