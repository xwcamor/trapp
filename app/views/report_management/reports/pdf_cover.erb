<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body {
      font-family: "Arial", sans-serif;
      margin: 0;
      padding: 0;
    }

    .header {
      height: 100px;
      position: relative;
    }

    .logo-right {
      position: absolute;
      top: 20px;
      right: 40px;
    }

    .cover-container {
      text-align: center;
      margin-top: 100px;
    }

    .customer-name {
      font-size: 26px;
      font-weight: bold;
      letter-spacing: 1px;
      margin-bottom: 20px;
      text-transform: uppercase;
    }

    .report-title {
      font-size: 22px;
      font-weight: normal;
      margin-bottom: 10px;
    }

    .separator {
      margin: 40px auto;
      width: 60%;
      border-top: 1px solid #444;
    }

    .footer-info {
      margin-top: 100px;
      font-size: 14px;
    }

    .no-toc h1, .no-toc h2, .no-toc h3 {
      page-break-after: avoid;
    }

    .no-toc {
      display: block;
    }    
  </style>
</head>
<body>
  <div class="header">
    <div class="logo-right">
      <%= wicked_pdf_image_tag asset_url('hitachi_logo_new.png'), width: "140", height: "70" %>
    </div>
  </div>
 
  <div class="cover-container">
    <div class="customer-name">
 
      <% if @report.customer.avatar.blank? %>
       
      <% else %>
       
        <img src="https://tr.dominio.com<%= @report.customer.avatar_url %>"   width="400" height="200" />   
      <% end %>
       <br>
      <%= @report.customer.name %> 
      
    </div>

    <div class="report-title">
      Análisis de Aceite Dieléctrico
    </div>

    <div class="separator"></div>

    <div class="footer-info">
      <p><strong>Fecha Generada:</strong> <%= @report.created_at.strftime("%d/%m/%Y") %></p>
      <p><strong>Reporte N°:</strong> <%= @report.id %></p>
      <p><strong>Generado por:</strong> <%= @report.user.str_complete_name %></p>
      <p><strong>Cantidad de Transformadores:</strong> <%= @report.report_details.size %></p>
    </div>
  </div>
</body>
</html>