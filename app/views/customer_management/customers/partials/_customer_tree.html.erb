<%= flash_messages %>
<link href="/assets/plugins/jstree/dist/themes/default/style.min.css" rel="stylesheet" />
<script src="/assets/plugins/jstree/dist/jstree.min.js"></script>
<div id="jstree-default" class="bg-white">
  <ul>
    <li class="jstree-node jstree-last jstree-open " aria-selected="true" data-jstree='{"icon":"fa fa-user"}' >
      <%= @customer.name.upcase %>
      <ul>
        <% @customer.customer_locations.where(deleted: 0,customer_id: @customer.id).each do  |location| %>
        <%# cache location do %>
        <li data-jstree='{"icon":"fa fa-building "}' class="jstree-node jstree-open">
          Ubicación: <%= location.name.upcase %>
          <% location.customer_areas.where(deleted: 0,customer_id: @customer.id).each do  |area| %>
          <ul>
            <li data-jstree='{"icon":"fa fa-buildings "}' class="jstree-node jstree-open">
              Área: <%= area.name.upcase  %>
              <ul>
                <% area.customer_substations.where(deleted: 0,customer_id: @customer.id).each do  |cs| %>
                <li data-jstree='{"icon":"fa fa-apartment "}'class="jstree-node jstree-open">
                  Subestación: <%= cs.name.upcase  %>  ( <%= cs.transformers.where("deleted=0").size %> transformadores )
                  <ul>
                    <% cs.transformers.where("deleted=0").each do |tr| %>
                    <li data-jstree='{"icon":"fa fa-transformer-bolt"}' >Serie: <%= tr.num_serie.upcase  %></li>
                    <% end %>
                  </ul> 
                </li>
                <% end %>
              </ul>
            </li>
  
          </ul>
          <% end %>
        </li>
        <%# end %>
        <% end %>
      </ul>

    </li>
  </ul>
</div>
 
<script>
  $("#jstree-default").jstree({
    "plugins": ["types"],
    "core": {
      "themes": { "responsive": true  }            
      },
    "types": {
      "default": { "icon": "fa fa-folder text-warning fa-lg" },
      "file": { "icon": "fa fa-file text-dark fa-lg" }
    }
  });
 

</script>