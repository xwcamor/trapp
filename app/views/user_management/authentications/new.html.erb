<div class="content__boxed w-100 min-vh-100 d-flex flex-column align-items-center justify-content-center">
   <div class="content__wrap">
      <!-- Login card -->
      <div class="card shadow-lg">
         <div class="card-header text-center bg-dark">
           <h3 class="text-white">Login - TR APP</h3>
         </div>

         <div class="card-body p-4">

            <div class="text-center mb-3">
              <%= image_tag asset_path('default_logo.png'), class: 'img-fluid logo' %>
            </div>

            <div class="d-flex justify-content-center mb-3">
              <a href="#" class="language-btn mx-2 active-language" data-lang="es">
                <span class="flag-icon flag-icon-es"></span>
              </a>
            </div>

            <div class="text-start">
              <p class="text-dark">Ingresa tu correo electrónico o usuario para acceder al sistema.</p>
            </div>
            
            <%= form_for @user, url: {action: "create"},:html=>{:class=>"mt-4 needs-validation",:novalidate=> :true} do |f|  %>
              <%= flash_messages %>
              <div class="form-group mb-3">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                  </div>
                  <%= f.text_field :username , :class=>"form-control", :placeholder=>"Usuario o Email", :required=> true, :autofocus => :true %>
                </div>
              </div>               

              <div class="form-group mb-3">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text"><i class="fas fa-key"></i></span>
                  </div>
                  <%= f.password_field :password, autocomplete: "off", class: "form-control", placeholder: t('devise.sessions.new.enter_password', default: 'Password'), required: true %>
                </div>          
              </div>

               <div class="d-grid">
                  <button name="button" type="submit" class="btn btn-primary btn-lg">
                     <i class="fas fa-sign-in-alt"></i> Iniciar Sesión
                  </button>
               </div>

             

            <% end %>

            <div class="d-flex justify-content-between gap-md-5 mt-4">
              <div class="form-check text-dark">
                <input class="form-check-input" type="checkbox" checked value="1" id="rememberMe" />
                <label for="_dm-loginCheck" class="form-check-label">Recordarme</label>
              </div>
              <a href="./forgot_password" class="btn-link text-decoration-none">¿Olvidaste tu contraseña?</a>
             
            </div>
            

          


            <div class="d-flex align-items-center  border-top pt-3 mt-3">  </div>
               <div class="text-dark">Al iniciar sesión, usted acepta nuestros <a target="_blank" href="/terms">Términos y Condiciones</a> y <a target="_blank" href="/privacy">Política de Privacidad</a></div>

            

            <div class="text-center text-muted mt-4 mb-2 small" style="font-size: 10px; line-height: 1.4;">
              <p class="mb-1">Este sistema es operado por <strong>Software BU</strong>.</p>
              <p class="mb-1">El contenido cargado por cada cliente es de su exclusiva responsabilidad.</p>
              <p class="mb-1">Software BU no está afiliado ni respalda a ninguna empresa<br> cuyos nombres o logos aparezcan cargados por usuarios.</p>
              <p class="mb-0 mt-2">© <%= Time.current.year %> <strong>Software BU</strong> – Todos los derechos reservados.</p>
            </div>



         </div>
      </div>

      <!-- END : Login card -->

   </div>
</div>



<style>
.logo {
  max-width: 300px; /* You can adjust this value to make the logo smaller or larger */
  width: 100%;
  height: auto;
}
   

</style>



<!-- Estilos Personalizados -->
<style>
 

  .language-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #f8f9fa;
    color: #333;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s;
    box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.1);
  }

  .language-btn:hover {
    background: #e2e6ea;
  }

  .language-btn.active-language {
    background: #007bff !important; /* Azul para indicar activo */
    color: #fff !important;
    transform: scale(1.1); /* Pequeño zoom al activo */
    box-shadow: 0 0 8px rgba(0, 123, 255, 0.5);
  }

  .flag-icon {
    font-size: 22px;
  }

</style>      