<div>
  <h2 class="semi-bold columns_2">Permisos  <%= link_to "Nuevo Permiso",{:controller=>"user_management/grants",:action=>"new",:parent_id=>@access.id},{ class: "btn btn-gray btn-xs"} %></p></h2> 
</div>

<div style="clear:both"></div> 

<%= flash_messages %>

  <section id="widget-grid" class="">
  <div class="row">

      <div class="jarviswidget jarviswidget-color-greenDark" id="wid-id-2" data-widget-editbutton="false" data-widget-deletebutton="false">
 

        <div>
           
          <div class="widget-body no-padding">
            <div class="table-responsive">
              <table class="table table-hover">
                <thead>
                <tr>
                  <th>#</th>
                  <th>Permiso</th>
                  <th>Acciones</th>
                </tr>
                </thead>
                <tbody>
                  <% @grants.each_with_index do |grant,index|%>
                  <tr class="array">
                    <td><%= @grants.offset + index + 1 %></td>
                    <td><%= grant.name %> (id: <%= grant.id %>)</td>
                    <td>
                      <%= link_to "<i class='fa fa-pencil'></i>".html_safe,{ :controller=>"user_management/grants",:action=>"edit",:id=>grant.id,:parent_id=>grant.parent_id}, :class => "btn btn-xs btn-default"  %>
                      <%= link_to "<i class='fa fa-times'></i>".html_safe,{ :controller=>"user_management/grants",:action=>"destroy",:id=>grant.id}, method: :delete, data: {confirm: "¿Estás seguro?"},class: "btn btn-xs btn-default"   %>
                    </td>
                  </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
     
      </div>

  </div>

</section>
 

<div style="float:right">
  <%= will_paginate @grants,:params =>params, :class=>'pagination', :previous_label=>"<i class='fa fa-arrow-left'></i>", :next_label=>"<i class='fa fa-arrow-right'></i>",inner_window: 1, outer_window: 1 %>
</div> 

 
<div class="page_info">
  <%= page_entries_info  @grants  , :page_links => false %>
</div>