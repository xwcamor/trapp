<% title "Accesos" %>
<%= links  link_to 'Configuraciones', [:configuration_management,:configurations] %> 


<div class="panela">
  <!-- begin panel-body -->
  <div class="panel-body">
    <h4 class="page-header">
    <i class="fa-solid fa-user"></i> Accesos
    <%= link_to "Nuevo",[:new_user_management,:access],{class: "btn btn-gray btn-xs"} %> 
    </h4>
    <h6>Total de Accesos: <%= @accesses.size %></h6>

  
     
  </div>
  <!-- end panel-body -->
</div>
<!-- end panel -->
 

  <hr>

<!-- begin row -->
<div class="row">
  <!-- begin col-10 -->
  <div class=" ">
    <!-- begin panel -->
    <div class="panel panel-inverse">
      <!-- begin panel-heading -->
      <div class="panel-heading">
        <h4 class="panel-title">Listado de Accesos</h4>
        <%= render :partial =>"layouts/panel_heading" %>
      </div>
      <!-- end panel-heading -->
      <!-- begin alert -->
      <%= flash_messages %>
      <!-- end alert -->
      <!-- begin panel-body -->
      <div class="panel-body">
         
        <table id="data-table-buttons-filter" class="table table-striped table-bordered align-middle">
          <thead>
            <tr>
              <th width="1%" data-orderable="false" class="sorting_disabled"></th>
              <th class="text-nowrap">Acceso</th>
              <th data-orderable="false" class="sorting_disabled"></th>
            </tr>
            <tr>
              <td width="1%"></td>
              <th class="text-nowrap">Acceso</th>
              <td></td>
            </tr>            
          </thead>
          <tbody>
            <% @accesses.each_with_index do |access,index| %>
            <tr>
              <td width="1%" class="f-s-600 text-inverse"><%= index + 1 %></td>
              <td><%= access.name %></td>

              <td>
                <%= link_to "<i class='fa fa-eye'></i>".html_safe, [:user_management, access] ,{:title=>"Ver",class: "btn btn-xs btn-default"} %>

                <%= link_to "<i class='fa fa-pencil'></i>".html_safe, [:edit, :user_management, access] ,{:title=>"Editar",:class=>"btn btn-xs btn-default"} %>

                <%= link_to "<i class='fa fa-trash'></i>".html_safe, [:user_management, access], method: :delete, data: {confirm: "¿Estás seguro?"},class: "btn btn-xs btn-default"  %>
              </td>
            </tr>
            <% end %>                  
          </tbody>
        </table>
      </div>
      <!-- end panel-body -->
    </div>
    <!-- end panel -->
  </div>
  <!-- end col-10 -->
</div>
<!-- end row -->
 

<%= render :partial =>"layouts/app_bottom_script" %>
<%= render :partial =>"layouts/table_manage_buttons" %>

 

 