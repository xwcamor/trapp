<li class="<%= active_link_to_class(furano_management_transformer_furanos_path(@transformer), :active => :exclusive)  %>">
  <a href="<%= furano_management_transformer_furanos_path(@transformer.id) %>" class="btn btn-default w-100 mb-2 text-start" ><i class="fa fa-search"></i> Búsqueda</a> 
</li>
<li>
  <a href="<%= furano_management_transformer_furanos_path(@transformer.id) %>" class="btn btn-default w-100 mb-2 text-start" ><i class="fa fa-broom"></i> Limpiar Búsqueda</a> 
</li>    
<li class="<%= active_link_to_class(new_furano_management_transformer_furano_path(@transformer), :active => :exclusive)  %>">
  <% if @user_permission.include?(58) %>
