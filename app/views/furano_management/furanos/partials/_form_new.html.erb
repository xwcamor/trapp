<%= flash_messages %>
<%= form_for [:furano_management, @furano],:html=>{'data-parsley-validate'=>"true", :autocomplete=>"off" } do |f| %> 
<!-- begin form -->
<div class="modal-header">
  <h4 class="modal-title">Nuevo Furano</h4>
</div>
<div class="modal-body">
  <div class="col-md-12">
    <div class="form-group row m-b-15">
      <label class="col-md-2 col-sm-4 col-form-label">Fecha de Ensayo</label>
      <div class="col-md-10 col-sm-8">
        <%= f.hidden_field :transformer_id , :value => params[:transformer_id] %>
        <%= f.hidden_field :deleted , :value => 0 %>

        <% if @transformer.has_special_testing_fur == 0%>
          <%= f.date_field :date_rehearsal, class: 'form-control  masked','data-parsley-required'=>"true" %>
        <% else %>  
          <%= f.datetime_field :date_rehearsal, class: 'form-control  masked','data-parsley-required'=>"true" %>
        <% end %>        
      </div>

      </div>
    </div>
    <br>    
    <div class="form-group row m-b-15">
      <label class="col-md-2 col-sm-4 col-form-label">2-Furfuraldehido <br> ppb</label>
      <div class="col-md-10 col-sm-8">
        <%= f.text_field :num_fal, class: 'form-control','data-parsley-type': "number",'data-parsley-required'=>"true",placeholder: "2-Furfuraldehido" %>
      </div>
    </div>
    <br>
    <div class="form-group row m-b-15">
      <label class="col-md-2 col-sm-4 col-form-label">5-Hidroxi-Metil-Furfuraldehido <br> ppb</label>
      <div class="col-md-10 col-sm-8">
        <%= f.text_field :num_hme, class: 'form-control','data-parsley-type': "number",'data-parsley-required'=>"true",placeholder: "5-Hidroxi-Metil-Furfuraldehido" %>
      </div>
    </div>    
    <br>
    <div class="form-group row m-b-15">
      <label class="col-md-2 col-sm-4 col-form-label">2-Acetilfurano <br> ppb</label>
      <div class="col-md-10 col-sm-8">
        <%= f.text_field :num_ace, class: 'form-control','data-parsley-type': "number",'data-parsley-required'=>"true",placeholder: "2-Acetilfurano" %>
      </div>
    </div>        
    <br>
    <div class="form-group row m-b-15">
      <label class="col-md-2 col-sm-4 col-form-label">5-Metil-2-Furfuraldehido <br> ppb</label>
      <div class="col-md-10 col-sm-8">
        <%= f.text_field :num_mfu, class: 'form-control','data-parsley-type': "number",'data-parsley-required'=>"true",placeholder: "5-Metil-2-Furfuraldehido" %>
      </div>
    </div>    
    <br>
    <div class="form-group row m-b-15">
      <label class="col-md-2 col-sm-4 col-form-label">2-Furfuril Alcohol <br> ppb</label>
      <div class="col-md-10 col-sm-8">
        <%= f.text_field :num_fua, class: 'form-control','data-parsley-type': "number",'data-parsley-required'=>"true",placeholder: "2-Furfuril Alcohol" %>
      </div>
    </div>   
  </div>
</div>
<!-- end modal-body -->
<!-- begin modal-footer -->
<div class="text-center">
 <button name="button" type="submit" class="btn btn-gray  me-1 mb-3 rounded-pill">
   <i class="fa-solid fa-floppy-disk"></i> Guardar Furano
 </button>
</div>
<!-- end modal-footer -->
<!-- end form --> 
<% end %> 