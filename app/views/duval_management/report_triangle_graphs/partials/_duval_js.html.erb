}

function calcMiddlePoint(type,p1,p2,p3){
  let total = p1 + p2 + p3;
  //get percent
  let percentAry = [p1, p2, p3], cpoints = [];
  percentAry = percentAry.map( x => parseFloat((x / total)) );
  var canvas1 = document.getElementById("normal");
  var normalCtx = canvas1.getContext("2d");

  var canvas2 = document.getElementById("middle");
  var middle = canvas2.getContext("2d");

  var canvas3 = document.getElementById("last");
  var last = canvas3.getContext("2d");

  let Cx = parseInt(calcRealPos(percentAry[0], percentAry[1]).x);
  let Cy = parseInt(calcRealPos(percentAry[0], percentAry[1]).y);
  // console.log(percentAry);
  switch(type){
    case "normal":
      drawMiddlePoint($("input.normal"), normalCtx, _SegmentPos1, Cx, Cy);
      break;
    case "middle":
      drawMiddlePoint($("input.middle"), middle, _SegmentPos2, Cx, Cy);
      break;
    case "last":
      drawMiddlePoint($("input.last"), last, _SegmentPos3, Cx, Cy);
      break;
  }
}
