    _RegistryPosition2[i].r = size;
    drawMiddlePoint($("input.middle"), middle, _SegmentPos2, point.x, point.y, size);
  }
  for ( let i = 0; i < _RegistryPosition3.length; i++ ){
    let point = _RegistryPosition3[i];
    //let size = 2 + 10 / _RegistryPosition3.length * (_RegistryPosition3.length - i); edited by CM
    let size = 10 + parseInt(10 / _RegistryPosition3.length * i);  
    _RegistryPosition3[i].r = size;
