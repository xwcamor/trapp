<% title "Análisis Duval" %>
<%= links  link_to 'Transformadores', [:transformer_management,:transformers] %> 
<!-- begin panel -->
<div class="panela">
  <!-- begin panel-body -->
  <div class="panel-body">
    <h4><i class='fa-solid fa-transformer-bolt'></i> Serie: <%= @transformer.num_serie.upcase %></h4>
    <h6><%= @transformer.customer_substation.customer_area.customer_location.customer.name.upcase %></h6>
    <%= render :partial =>"transformer_management/transformers/partials/info_transformer" %> 
  </div>
  <!-- end panel-body -->
</div>
<!-- end panel --> 

<!-- begin menu-tab -->
<div id="tab_menus">
 <%= render :partial =>"transformer_management/transformers/partials/menu_options" %> 
</div>
<!-- end menu-tab -->

<div class="row bg-default">
<!-- begin mailbox -->
<div class="mailbox bg-default ps-0 pe-0">
  <!-- begin mailbox-sidebar -->
  <div class="mailbox-sidebar bg-default">
    <!-- begin mailbox-sidebar-header -->
    <div class="mailbox-sidebar-header d-flex justify-content-center">
      <a href="#emailNav" data-bs-toggle="collapse" class="btn btn-dark btn-sm me-auto d-block d-lg-none">
      <i class="fa fa-cog"></i> <h5>OPCIONES</h5>
      </a>
      <h5 class="pt-2"> Resultados: <%= @list_chromatographicals.size %></h5>
    </div>  
    <!-- end mailbox-sidebar-header -->  
    <!-- begin mailbox-sidebar-content -->
    <div class="mailbox-sidebar-content d-lg-block collapse" id="emailNav">
      <div data-scrollbar="true" data-height="100%" data-skip-mobile="true" class="ps" data-init="true" style="height: 100%;">
        <div class="nav-title"><b>OPCIONES</b></div>
        <ul class="nav nav-inbox">
          <%= render :partial =>"chromatographical_management/chromatographicals/partials/sidebar_options" %>                     
        </ul>
      </div> 
    </div>
    <!-- end mailbox-sidebar-content -->
  </div>
  <!-- end mailbox-sidebar -->
  <!-- begin mailbox-content -->
  <div class="mailbox-content bg-default pt-2 rounded-3 pe-0"> 
    <div class="table-responsive">
      <!-- begin panel -->
      <div class="panel panel-inverse" >
        <!-- begin panel-heading -->
        <div class="panel-heading bg-gray-800 text-white">
          <i class="fa-regular fa-syringe text-white pe-2"></i>
          <h4 class="panel-title">Análisis - Triángulo Duval</h4>
          <%= render :partial =>"layouts/panel_heading_fullscreen" %>
        </div>
        <!-- end panel-heading -->
        <!-- begin panel-body -->
        <div class="panel-body bordered table-responsive">
          <div class="row">
            <div class="col-6 text-start">          
              <h6>
              <i class="fa-solid fa-chart-scatter"></i> Análisis por Triángulo Duval

                <a href="<%= duval_management_transformer_last_triangle_graphs_path(@transformer.id) %>" class="btn btn-gray rounded-pill btn-xs"><i class="fa-solid fa-chart-scatter"></i> Triángulo Duval</a>
                
                <a href="<%= duval_management_transformer_last_pentagon_graphs_path(@transformer.id) %>" class="btn btn-default rounded-pill btn-xs"><i class="fa-solid fa-chart-scatter"></i> Pentágono Duval</a>    
              </h6>               
            </div>

            <div class="col-6 text-end ">
              <div type="all">
                  <a href="<%= duval_management_transformer_last_triangle_graphs_path(@transformer) %>" class="btn btn-gray rounded-pill btn-xs"> <i class='fa fa-circle'></i> Mostrar último Ensayo </a>
                  <a href="<%= duval_management_transformer_triangle_graphs_path(@transformer) %>" class="btn btn-default rounded-pill btn-xs"> <i class='fa fa-circle'></i> Mostrar Ensayos </a>
              </div>               
            </div>     
          </div>             
          <%= render :partial =>"duval_management/last_triangle_graphs/partials/triangle_graphs" %>
        </div>
        <!-- end panel-body -->
      </div>
      <!-- end panel -->          
    </div>
  </div>
  <!-- end mailbox-content -->
</div>
<!-- end mailbox -->
</div>
 
<!-- begin script-->
<%= render :partial =>"layouts/app_bottom_script" %>
<!-- end script--> 

<!-- begin notification--> 
<%= render :partial =>"duval_management/last_triangle_graphs/partials/legend_notifications" %>  
<!-- end notification--> 