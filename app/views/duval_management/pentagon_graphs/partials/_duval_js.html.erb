      infoDiv.show();
      infoDiv.find("label:last-child").html("");
      infoDiv.find(".date").html(rPoint.str_date_rehearsal);
      infoDiv.find("label.h2gas").html(rPoint.num_hid);
      infoDiv.find("label.c2h2").html(rPoint.num_ace);
      infoDiv.find("label.c2h4").html(rPoint.num_eti);
      infoDiv.find("label.ch4").html(rPoint.num_met);
      infoDiv.find("label.c2h6").html(rPoint.num_eta);
      infoDiv.find("label.pn1_hid_percent").html(rPoint.pn1_hid_percent);
      infoDiv.find("label.pn1_met_percent").html(rPoint.pn1_met_percent);
      infoDiv.find("label.pn1_eti_percent").html(rPoint.pn1_eti_percent);
      infoDiv.find("label.pn1_eta_percent").html(rPoint.pn1_eta_percent);
      infoDiv.find("label.pn1_ace_percent").html(rPoint.pn1_ace_percent);                              
    }
    else
      infoDiv.hide();
  });
});

function getDate(dateString){
  let dateAry = dateString.split("-");
  let rdate = new Date(dateAry[2], dateAry[1] - 1, dateAry[0]);
  return rdate;
}

function drawSegment(ctx, s, centpos, ratio) {
  // draw and fill the segment path
  ctx.beginPath();
  ctx.moveTo(centpos.x + s.points[0].x * ratio, centpos.y - s.points[0].y*ratio);
  for (var i = 1; i < s.points.length; i++) {
    ctx.lineTo(centpos.x + s.points[i].x * ratio, centpos.y - s.points[i].y*ratio);
  }
  ctx.closePath();
  ctx.fillStyle = s.fill;
  ctx.fill();
  ctx.lineWidth = 1;
  ctx.strokeStyle = s.fill;
  ctx.stroke();
  // draw segment's box label
  if (s.label.withLine) {
    lineBoxedLabel(ctx, s, labelfontsize, labelfontface, labelpadding, centpos, ratio);
  } else {
    boxedLabel(ctx, s, labelfontsize, labelfontface, labelpadding, centpos, ratio);
  }
}

function boxedLabel(ctx, s, fontsize, fontface, padding, centpos, ratio) {
  var centerX = centpos.x + s.label.cx * ratio;
  var centerY = centpos.y - s.label.cy * ratio;
  var text = s.label.text;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.font = fontsize + 'px ' + fontface;
  var textwidth = ctx.measureText(text).width;
  var textheight = fontsize * 1.286;
  var leftX = centerX - textwidth / 2 - padding;
  var topY = centerY - textheight / 2 - padding;
  ctx.fillStyle = 'white';
  // ctx.fillRect(leftX, topY, textwidth + padding * 2, textheight + padding * 2);
  ctx.lineWidth = 1;
  // ctx.strokeRect(leftX, topY, textwidth + padding * 2, textheight + padding * 2);
  ctx.fillStyle = 'black';
  ctx.fillText(text, centerX, centerY);
}


function lineBoxedLabel(ctx, s, fontsize, fontface, padding, centpos, ratio) {
  var centerX = centpos.x + s.label.cx * ratio;
  var centerY = centpos.y - s.label.cy * ratio;
  var text = s.label.text;
  var lineToX = centpos.x + s.label.endX * ratio;
  var lineToY = centpos.y + s.label.endY * ratio;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle'
  ctx.font = fontsize + 'px ' + fontface
  var textwidth = ctx.measureText(text).width;
  var textheight = fontsize * 1.286;
  var leftX = centerX - textwidth / 2 - padding;
  var topY = centerY - textheight / 2 - padding;
  // the line
  ctx.beginPath();
  ctx.moveTo(leftX+textwidth, topY + textheight / 2);
  ctx.lineTo(lineToX, topY + textheight / 2);
  ctx.strokeStyle = 'black';
  ctx.lineWidth = 1;
  ctx.stroke();
  // the boxed text
  ctx.fillStyle = 'white';
  // ctx.fillRect(leftX, topY, textwidth + padding * 2, textheight + padding * 2);
  // ctx.strokeRect(leftX, topY, textwidth + padding * 2, textheight + padding * 2);
  ctx.fillStyle = 'black';
  ctx.fillText(text, centerX, centerY);
}

function moleculeLabel(V, P, text) {
  var dx = V.x - P.x;
  var dy = V.y - P.y;
  var rAngle = Math.atan2(dy, dx);
  var padding = 15; // == how far outside the pentagon you want to go
  var outsideX = P.x + (P.radius + padding) * Math.cos(rAngle);
  var outsideY = P.y + (P.radius + padding) * Math.sin(rAngle);
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = 'black';
  ctx.fillText(text, outsideX, outsideY);
}


/**
 * draw basic pentagon.
 **/
function drawPentagon(inputPoints) {
  // console.log(inputPoints);
  // let centerPos = {x: inputPoints[0].x, y: inputPoints[0].y};
  ctx.beginPath();
  ctx.moveTo(inputPoints[0].x, inputPoints[0].y);
  for (var i = 1; i < inputPoints.length; i++) {
    ctx.lineTo(inputPoints[i].x, inputPoints[i].y);
    ctx.moveTo(inputPoints[i].x, inputPoints[i].y);
  }
  ctx.lineTo(inputPoints[0].x, inputPoints[0].y);

  ctx.strokeStyle = 'red';
  ctx.lineWidth = 2;
  ctx.stroke();
  ctx.closePath();
}

function drawLegend(texts, x, y, lineheight) {
  ctx.textAlign = 'left';
  ctx.textBaseline = 'top';
  ctx.fillStyle = 'black';
  ctx.font = '12px arial';
  for (var i = 0; i < texts.length; i++) {
    ctx.fillText(texts[i], x, y + i * lineheight);
  }
}

function drawMiddlePoint(ctx, segment, cx, cy, type, size = 10){
    // draw the polygon
    ctx.beginPath();

    let startX = _CenterPoint.x + cx*_Ratio;
    let startY = _CenterPoint.y - cy*_Ratio;

    let currentArea = "";
    let point = {x: startX, y:startY};
    for(let i = 0; i < segment.length; i++){
      let points = segment[i].points;
      let polygon = [];
      for (var j = 0; j < points.length; j++) {
        let iPoint = {x: 0, y: 0};
        iPoint.x = _CenterPoint.x + points[j].x * _Ratio;
        iPoint.y = _CenterPoint.y - points[j].y * _Ratio;
        polygon.push(iPoint);
      }
      if (  IsPointInPolygon(point, polygon) )
        currentArea = segment[i].label.text;
    }

    ctx.arc(startX, startY,size,0,Math.PI*2);
    ctx.strokeStyle='white';
    ctx.fillStyle='black';   ///edited by CM 2022
    ctx.fill();
    ctx.stroke();
    
    let result = currentArea;
    $("div.pentagon input."+type).val(result);
    // ctx.textBaseline = 'middle';
    // ctx.font = 12 + 'px ';
    // var textwidth = ctx.measureText(result).width;
    // var textheight = 12 * 1.286;
    // let leftX = _CenterPoint.x;
    // let topY = _CenterPoint.y + 40 * _Ratio;
    // let padding = 2;
    // ctx.fillStyle = 'white';
    // ctx.fillRect(leftX - textwidth/2, topY - textheight/2, textwidth + padding * 2, textheight + padding * 2);
    // ctx.fillStyle = 'black';
    // ctx.fillText(result, leftX, topY);
    ctx.closePath();
}

function draw(ctx, points, centpos, ratio){
    // draw the polygon
    ctx.beginPath();
    ctx.moveTo(centpos.x + points[0].x*ratio, centpos.y - points[0].y*ratio);
    for(var i=1;i<points.length;i++){
        ctx.lineTo(centpos.x + points[i].x*ratio, centpos.y - points[i].y*ratio);
    }
    ctx.stroke();
    
    // draw the labels at their radial extension points
    ctx.textAlign='center';
    ctx.textBaseline='middle';
    var padding = 3;
    let labelTexts = ["H2","C2H2","C2H4","CH4","C2H6"];
    for(var i=0; i < points.length-1; i++){
        var p = points[i];
        var dx = p.x;
        var dy = p.y;
        var dist = Math.sqrt(dx * dx + dy * dy);
        var rAngle = Math.atan2(dy, dx);
        var labelX = centpos.x + (dist + padding) * Math.cos(rAngle) * ratio;
        if ( i == 0 )
          padding = 1;
        else
          padding = 3;
        var labelY = centpos.y - (dist + padding) * Math.sin(rAngle) * ratio;
        ctx.fillText(labelTexts[i], labelX, labelY)
        
        ctx.beginPath();
        ctx.strokeStyle='black';
        ctx.stroke();
        //ctx.fillStyle='red';
        //ctx.fill();
        ctx.strokeStyle='black';
        ctx.fillStyle='black';
    }   
}

function resetCanvas(centPos, ratio, type){
  var canvas1 = document.getElementById("normal");
  var normalCtx = canvas1.getContext("2d");
 

  var canvas2 = document.getElementById("combine");
  var combine = canvas2.getContext("2d");
 

  var canvas3 = document.getElementById("faultzone");
  var faultzone = canvas3.getContext("2d");
 

  for (var i = 0; i < _SegmentPos.length; i++) {
    if ( type == "normal" || type == "all")
      drawSegment(normalCtx, _SegmentPos[i],centPos,ratio);
    if ( type == "faultzone" || type == "all")
      drawSegment(faultzone, _SegmentPosFaultZone[i],centPos,ratio);
  }
  
  for (var i = 0; i < _SegmentPosCombine.length; i++) {
    if ( type == "combine" || type == "all")
      drawSegment(combine, _SegmentPosCombine[i],centPos,ratio);
  }
  draw(normalCtx, _MainPoints, centPos, ratio);
  draw(combine, _MainPoints, centPos, ratio);
  draw(faultzone, _MainPoints, centPos, ratio);
}

function IsPointInPolygon( p, polygon )
{
    let minX = polygon[ 0 ].x;
    let maxX = polygon[ 0 ].x;
    let minY = polygon[ 0 ].y;
    let maxY = polygon[ 0 ].y;
    for ( var i = 0 ; i < polygon.length ; i++ )
    {
        let q = polygon[ i ];
        if ( q.x < minX ) minX = q.x;
        if ( q.x > maxX ) maxX = q.x;
        if ( q.y < minY ) minY = q.y;
        if ( q.y > maxY ) maxY = q.y;
    }
    
    if ( p.x < minX || p.x > maxX || p.y < minY || p.y > maxY )
    {
        return false;
    }

    let inside = false;
    for ( let i = 0, j = polygon.length - 1 ; i < polygon.length ; j = i++ )
    {
        if ( ( polygon[ i ].y > p.y ) != ( polygon[ j ].y > p.y ) && p.x < ( polygon[ j ].x - polygon[ i ].x ) * ( p.y - polygon[ i ].y ) / ( polygon[ j ].y - polygon[ i ].y ) + polygon[ i ].x )
        {
            inside = !inside;
        }
    }

    return inside;
}

