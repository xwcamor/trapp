<script type="text/javascript">
var _CenterPoint = {x: 220, y: 220};
var labelfontsize = 12;
var labelfontface = 'verdana';
var labelpadding = 3;
var legendTexts = ['PD = Partial Discharge', 'T1 = Thermal fault < 300 celcius', '...'];
_Ratio = 4.5;    //edited by CM
$(document).ready(function graph_pentagon(){
  //offset :  
  resetCanvas(_CenterPoint, _Ratio, "all");
  // $.getJSON("segment.json", function(data) {
    // _RegistryData = data;
    _RegistryData.sort(function(a,b){
      let adate = getDate(a.str_date_rehearsal);
      let bdate = getDate(b.str_date_rehearsal);
      return adate - bdate;
    });
    DrawRegistryPoint(_RegistryData);
  // });
  $("input").change(function(){
    $("button#calc").trigger("click");
  });

  $("button#registry").click(function(){
    resetCanvas(_CenterPoint, _Ratio, "all");
    DrawRegistryPoint(_RegistryData);
  });
  $("button#calc").click(function(){
    let type = $(this).parent().attr("type");
    resetCanvas(_CenterPoint, _Ratio, type);

    let h2 = parseInt($("input#h2").val());
    let ch4 = parseInt($("input#ch4").val());
    let c2h2 = parseInt($("input#c2h2").val());
    let c2h4 = parseInt($("input#c2h4").val());
    let c2h6 = parseInt($("input#c2h6").val());
    let total = ch4 + c2h2 + c2h4 + c2h6 + h2;
    //get percent
    let percentAry = [c2h2, c2h4, ch4, c2h6, h2], cpoints = [];
    let anguloAry = [18, 306, 234, 162, 90];
    let radianAry = [0.31416, 5.34071, 4.08407, 2.82743, 1.5708];
    percentAry = percentAry.map( x => parseFloat((x / total * 100)) );
    // console.log(percentAry);
    for(let i = 0; i < percentAry.length; i++){
      let pos = {x: 0, y: 0};
      pos.x = parseFloat( (percentAry[i] * Math.cos(radianAry[i])).toFixed(3) );
      pos.y = parseFloat( (percentAry[i] * Math.sin(radianAry[i])).toFixed(3) );
      cpoints[i] = pos;
    }
    //get Area del pentagonc
    let Area = 0;
    for(let i = 0; i < cpoints.length; i++){
      let vari = cpoints[i].x * cpoints[ (i+1)%cpoints.length ].y - cpoints[ (i+1)%cpoints.length ].x * cpoints[i].y;
      Area += vari;
    }
    Area /= 2;

    //get Centroide point
    let Cx = 0, Cy = 0;
    for(let i = 0; i < cpoints.length; i++){
      let cp = cpoints[i];
      let np = cpoints[ (i+1) % cpoints.length ];
      Cx += (cp.x + np.x) * (cp.x*np.y - np.x*cp.y);
      Cy += (cp.y + np.y) * (cp.x*np.y - np.x*cp.y);
    }
    Cx /= 6*Area;
    Cy /= 6*Area;
    var canvas1 = document.getElementById("normal");
    var normalCtx = canvas1.getContext("2d");
 

    var canvas2 = document.getElementById("combine");
    var combine = canvas2.getContext("2d");
 

