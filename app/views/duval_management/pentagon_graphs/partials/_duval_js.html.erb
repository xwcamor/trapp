    let size = 2 + parseInt(10 / points.length * i);    
    let startX = _CenterPoint.x + Cx*_Ratio;
    let startY = _CenterPoint.y - Cy*_Ratio;
    let point = {x: startX, y: startY, r: size};
    _RegistryPosition.push(point);

    drawMiddlePoint(normalCtx, _SegmentPos, Cx, Cy, "normal", size);
    drawMiddlePoint(combine, _SegmentPosCombine, Cx, Cy, "combine", size);
    drawMiddlePoint(faultzone, _SegmentPosFaultZone, Cx, Cy, "faultzone", size);
    
  }
}

</script>