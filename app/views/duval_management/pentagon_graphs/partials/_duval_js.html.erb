    }
    //get Area del pentagonc
    let Area = 0;
    for(let j = 0; j < cpoints.length; j++){
      let vari = cpoints[j].x * cpoints[ (j+1)%cpoints.length ].y - cpoints[ (j+1)%cpoints.length ].x * cpoints[j].y;
      Area += vari;
    }
    Area /= 2;

    //get Centroide point
    let Cx = 0, Cy = 0;
    for(let j = 0; j < cpoints.length; j++){
      let cp = cpoints[j];
      let np = cpoints[ (j+1) % cpoints.length ];
      Cx += (cp.x + np.x) * (cp.x*np.y - np.x*cp.y);
      Cy += (cp.y + np.y) * (cp.x*np.y - np.x*cp.y);
