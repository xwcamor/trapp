    var faultzone = canvas3.getContext("2d");
    switch(type){
      case "all":
        drawMiddlePoint(normalCtx, _SegmentPos, Cx, Cy, "normal");
        drawMiddlePoint(combine, _SegmentPosCombine, Cx, Cy, "combine");
        drawMiddlePoint(faultzone, _SegmentPosFaultZone, Cx, Cy, "faultzone");
        break;
      case "normal":
        drawMiddlePoint(normalCtx, _SegmentPos, Cx, Cy, type);
        break;
      case "combine":
        drawMiddlePoint(combine, _SegmentPosCombine, Cx, Cy, type);
        break;
      case "faultzone":
        drawMiddlePoint(faultzone, _SegmentPosFaultZone, Cx, Cy, type);
        break;
    }
  });

  $("canvas").mousemove(function(e){
    let cPos = {x: e.offsetX, y: e.offsetY}, selectIndex = -1;
    for(let i in _RegistryPosition){
      let rPoint = _RegistryPosition[i];
